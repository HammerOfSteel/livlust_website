# Copy this file to .env and fill in values

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=livlust
POSTGRES_PASSWORD=changeme
POSTGRES_DB=livlust_db

# ── Directus CMS ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomUUID())"
DIRECTUS_KEY=replace-with-random-uuid
DIRECTUS_SECRET=replace-with-long-random-string

DIRECTUS_ADMIN_EMAIL=admin@livlust.se
DIRECTUS_ADMIN_PASSWORD=changeme

# ── Frontend ───────────────────────────────────────────────
# URL to reach Directus admin from the BROWSER (not Docker-internal)
VITE_CMS_URL=http://localhost:8055

# Theme: ocean | forest | nordic | sunset | lavender
VITE_THEME=ocean
